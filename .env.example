# ─── Telegram API ───────────────────────────────────────────
# https://my.telegram.org → API development tools
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# Comma-separated numeric Telegram user IDs allowed to press buttons / issue commands
# (get yours from @userinfobot)
REVIEWER_IDS=

# Internal review chat. You review by DMing the bot directly, so leave this BLANK to
# default to your (first REVIEWER_IDS) private chat. Only set it to override the target.
INTERNAL_CHAT_ID=

# Public broadcast channel (negative id starting with -100…)
BROADCAST_CHANNEL_ID=

# ─── Facebook (Graph API) ───────────────────────────────────
# Page access token + numeric Page ID.
# Wymagane scopes: pages_manage_posts (publikacja),
#   pages_manage_engagement + pages_read_engagement (komentarz PROMO), pages_show_list.
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=

# ─── Claude ─────────────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── Crawler GIS (opcjonalne — domyślne wartości w config.py) ─
# Interwał sprawdzania w sekundach (ustawiany też w deploy.sh)
CRAWLER_INTERVAL=600
# GIS_LISTING_URL=https://www.gov.pl/web/gis/ostrzezenia
# CRAWLER_OUTPUT_DIR=gis_alerts
